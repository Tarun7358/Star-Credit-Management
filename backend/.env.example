# Supabase PostgreSQL Connection String (Transaction Mode / Direct)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?schema=backend"

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (generate a strong random string in production)
JWT_SECRET="star-credit-management-secret-key-super-secure"

# Default owner account password for database seeding (first run only)
DEFAULT_OWNER_PASSWORD="Password123"

# CORS allowed origins
FRONTEND_URL="http://localhost:5173"
ADMIN_PANEL_URL="http://localhost:5174"
